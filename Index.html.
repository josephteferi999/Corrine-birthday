<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Happy Birthday Corrine ❤️</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:linear-gradient(135deg,#ff9ecf,#ffd6e8);
    min-height:100vh;
    overflow:hidden;
}

.page{
    display:none;
    min-height:100vh;
    padding:30px;
    justify-content:center;
    align-items:center;
    text-align:center;
    flex-direction:column;
}

.active{
    display:flex;
}

h1{
    font-size:2.2rem;
    margin-bottom:20px;
    color:#fff;
}

p{
    font-size:1.2rem;
    max-width:700px;
    line-height:1.6;
    color:white;
    margin-bottom:20px;
}

button{
    border:none;
    padding:15px 30px;
    border-radius:50px;
    font-size:1rem;
    cursor:pointer;
    margin:10px;
}

.main-btn{
    background:white;
}

.yes-btn{
    background:white;
}

.no-btn{
    background:#fff;
    position:absolute;
}

#confetti{
    font-size:4rem;
    animation:bounce 1s infinite;
}

@keyframes bounce{
    50%{transform:translateY(-15px);}
}
</style>
</head>
<body>

<div id="page1" class="page active">
    <h1>🎉 Happy Birthday Corrine 🎉</h1>

    <p>
        Happy Birthday to the most beautiful, coolest, and most straightforward
        person I've ever met.
    </p>

    <p>
        Every conversation with you somehow manages to make my day better.
        You're funny, stubborn, honest, and completely unforgettable.
    </p>

    <p>
        Today is all about you, Abs ❤️
    </p>

    <button class="main-btn" onclick="nextPage()">Click Here ❤️</button>
</div>

<div id="page2" class="page">
    <h1>Abs, I have a question... 🥺</h1>

    <p style="font-size:1.7rem;">
        Can I take you on our first date? ❤️
    </p>

    <div>
        <button class="yes-btn" onclick="yesClicked()">YES 💕</button>
        <button id="noBtn" class="no-btn">NO 😈</button>
    </div>
</div>

<div id="page3" class="page">
    <div id="confetti">🎊🎉🎊</div>

    <h1>HAPPY BIRTHDAY AGAIN CORRINE ❤️</h1>

    <p>
        I knew you'd say yes 😌
    </p>

    <p>
        I can't wait for our first date.
    </p>

    <p>
        Until then, enjoy your special day and keep being the amazing person
        I've come to care about.
    </p>

    <p>
        — Joseph ❤️
    </p>
</div>

<script>

function nextPage(){
    document.getElementById("page1").classList.remove("active");
    document.getElementById("page2").classList.add("active");
}

function yesClicked(){
    document.getElementById("page2").classList.remove("active");
    document.getElementById("page3").classList.add("active");
}

const noBtn = document.getElementById("noBtn");

function moveButton(){
    const maxX = window.innerWidth - 120;
    const maxY = window.innerHeight - 80;

    const x = Math.random() * maxX;
    const y = Math.random() * maxY;

    noBtn.style.left = x + "px";
    noBtn.style.top = y + "px";
}

noBtn.addEventListener("mouseover", moveButton);
noBtn.addEventListener("touchstart", moveButton);

</script>

</body>
</html>
